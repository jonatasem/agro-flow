generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url = env("DATABASE_URL") //ignore o erro, nao é obrigatorio utilizar acelador na versao 6.19 do prisma, versao compativel com o mongodb.
}

model Official {
  id String   @id @map("_id") @default(auto()) @db.ObjectId
  name      String
  registration     String
  city     String
  status    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("official")
}
