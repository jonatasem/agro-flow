generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url = env("DATABASE_URL")
}

model Official {
  id String   @id @map("_id") @default(auto()) @db.ObjectId
  name      String
  registration     String
  city     String
  status    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("official")
}

model Equipment {
  id String   @id @map("_id") @default(auto()) @db.ObjectId
  name     String
  fleet      String
  city     String
  status    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("equipment")
}


model Operator {
  id String   @id @map("_id") @default(auto()) @db.ObjectId
  name     String
  registration     String
  city     String
  status    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("operator")
}